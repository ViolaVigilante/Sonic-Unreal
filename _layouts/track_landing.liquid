---
layout: default
---
<article {% if page.feature-img %}class="feature-image"{% endif %}>
    <header id="main" style="background-image: url('{{ page.feature-img | relative_url }}')">
        <div class="title-padder">
            {% if page.hide_title %}
                <div class="feature-image-padding"></div>
            {% else %}
                <h1 id="{{ page.title | default: "" | cgi_escape }}" class="title"> {{ page.title }}</h1>
                {% if page.subtitle %}
                    <h2 class="subtitle">{{ page.subtitle }}</h2>
                {% endif %}
            {% endif %}
        </div>
    </header>

    <section class="post-content">
    {% if page.bootstrap %}
        <div class="bootstrap-iso">
            {% endif %}
            {{ content }}
            {% if page.bootstrap %}
        </div>
        {% endif %}
    </section>

    <!-- Bootstrap Offcanvas for breadcrumbs -->
    <div class="breadcrumb-button-container" style="position: fixed; left: 3%; bottom: 50%; z-index: 1000;">
        <button class="breadcrumb-button" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasExample" aria-controls="offcanvasExample">
            Recently Visited Pages
        </button>
    </div>

    <div class="offcanvas offcanvas-start" tabindex="-1" id="offcanvasExample" aria-labelledby="offcanvasExampleLabel">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title" id="offcanvasExampleLabel">Recently Visited Pages</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            <div>
            {% include breadcrumbs2.html %}
            </div>
        </div>
    </div>

    <!-- Looks for which track(s) a page is a part of, then initializes colored next/previous page buttons as appropriate for each track -->
    <section class="next-previous-page-buttons">
        <div class="esports-track">
            {% if page.esports-track %}
                {% if page.next-esports-page and page.previous-esports-page %}
                    {% include buttons/esports_next_and_previous.html %}
                {% elsif page.next-esports-page %}
                    {% include buttons/esports_next_page.html %}
                {% elsif page.previous-esports-page %}
                    {% include buttons/esports_previous_page.html %}
                {% endif %}
            {% endif %}
        </div>
        <div class="nightlife-track">
            {% if page.nightlife-track %}
                {% if page.next-nightlife-page and page.previous-nightlife-page %}
                    {% include buttons/nightlife_next_and_previous.html %}
                {% elsif page.next-nightlife-page %}
                    {% include buttons/nightlife_next_page.html %}
                {% elsif page.previous-nightlife-page %}
                    {% include buttons/nightlife_previous_page.html %}
                {% endif %}
            {% endif %}
        </div>
        <div class="virtual-concerts-track">
            {% if page.virtual-concerts-track %}
                {% if page.next-virtual-concerts-page and page.previous-virtual-concerts-page %}
                    {% include buttons/virtual_concerts_next_and_previous.html %}
                {% elsif page.next-virtual-concerts-page %}
                    {% include buttons/virtual_concerts_next_page.html %}
                {% elsif page.previous-virtual-concerts-page %}
                    {% include buttons/virtual_concerts_previous_page.html %}
                {% endif %}
            {% endif %}
        </div>
        <div class="immersion-track">
            {% if page.immersion-track %}
                {% if page.next-immersion-page and page.previous-immersion-page %}
                    {% include buttons/immersion_next_and_previous.html %}
                {% elsif page.next-immersion-page %}
                    {% include buttons/immersion_next_page.html %}
                {% elsif page.previous-immersion-page %}
                    {% include buttons/immersion_previous_page.html %}
                {% endif %}
            {% endif %}
        </div>
        <div class="liveness-track">
            {% if page.liveness-track %}
                {% if page.next-liveness-page and page.previous-liveness-page %}
                    {% include buttons/liveness_next_and_previous.html %}
                {% elsif page.next-liveness-page %}
                    {% include buttons/liveness_next_page.html %}
                {% elsif page.previous-liveness-page %}
                    {% include buttons/liveness_previous_page.html %}
                {% endif %}
            {% endif %}
        </div>
        <div class="virtuality-track">
            {% if page.virtuality-track %}
                {% if page.next-virtuality-page and page.previous-virtuality-page %}
                    {% include buttons/virtuality_next_and_previous.html %}
                {% elsif page.next-virtuality-page %}
                    {% include buttons/virtuality_next_page.html %}
                {% elsif page.previous-virtuality-page %}
                    {% include buttons/virtuality_previous_page.html %}
                {% endif %}
            {% endif %}
        </div>
    </section>

    <!-- Tag Cloud -->
    <div class="container" style="background-color:coral;">
        <div class="row">
            <div class="col">
                <h3 style="text-align: center;">Explore Within This Track</h3>
            </div>
        </div>
        <div class="row">
            <div class="col">
                <p style="text-align: center;">Display cloud of clickable tags present within this track</p>
            </div>
        </div>
    </div>
</article>
